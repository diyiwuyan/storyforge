{
  "name": "storyforge",
  "version": "1.2.0",
  "description": "StoryForge - Electron + React + Vite + TypeScript",
  "main": "electron/main/index.js",
  "scripts": {
    "dev": "tsc -p tsconfig.node.json && concurrently \"vite\" \"tsc -p tsconfig.node.json --watch\" \"node scripts/wait-and-launch.js\"",
    "build": "tsc -p tsconfig.node.json && vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.4",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^31.7.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  }
}
